  "ingredients": [
    {
      "name": "extra firm tofu",
      "amount": "1 block",
      "notes": "drained and crumbled"
    },
    {
      "name": "semi-skimmed milk",
      "amount": "1/2 cup"
    },
    {
      "name": "confit tomato",
      "amount": "1/2 cup",
      "notes": "chopped"
    },
    {
      "name": "whole wheat breadcrumbs",
      "amount": "1/2 cup"
    },
    {
      "name": " nutritional yeast",
      "amount": "2 tablespoons"
    },
    {
      "name": "olive oil",
      "amount": "1 tablespoon"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/4 teaspoon"
    }
  ],
  "instructions": [
    "Preheat the oven to 375 degrees Fahrenheit.",
    "In a bowl, whisk together the semi-skimmed milk, nutritional yeast, salt, and black pepper.",
    "Add the crumbled tofu to the bowl and mix until well combined.",
    "Stir in the chopped confit tomato.",
    "Divide the tofu mixture into 4 equal parts and shape each part into a ball.",
    "Roll each ball in the whole wheat breadcrumbs to coat.",
    "Place the coated tofu balls on a baking sheet lined with parchment paper.",
    "Drizzle the olive oil over the tofu balls.",
    "Bake the tofu balls in the preheated oven for 20 minutes."
  ],
