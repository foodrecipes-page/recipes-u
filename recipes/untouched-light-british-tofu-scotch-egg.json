{
  "title": "Untouched Light British Tofu Scotch Egg",
  "description": "A plant-based twist on the classic Scotch egg, featuring tofu and confit tomato, served on a tagliere board for a light and satisfying meal.",
  "cuisine": "British",
  "diet": [
    "vegetarian",
    "vegan"
