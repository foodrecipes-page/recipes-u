  "ingredients": [
    {
      "name": "small potatoes",
      "amount": "1 1/2 pounds",
      "notes": "peeled and cubed"
    },
    {
      "name": "tempering chocolate",
      "amount": "2 ounces",
      "notes": "grated"
    },
    {
      "name": "gochujang",
      "amount": "2 tablespoons"
    },
    {
      "name": "soy sauce",
      "amount": "1 tablespoon"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "ginger",
      "amount": "1 inch",
      "notes": "grated"
    },
    {
      "name": "coconut milk",
      "amount": "1 can"
    },
    {
      "name": "sesame oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "green onions",
      "amount": "1/4 cup",
      "notes": "chopped"
    },
    {
      "name": "toasted sesame seeds",
      "amount": "1 tablespoon"
    }
  ],
  "instructions": [
    "In a large pot, heat the sesame oil over medium heat.",
    "Add the minced garlic and grated ginger and saute for 1 minute.",
    "Add the cubed potatoes, gochujang, and soy sauce, and stir to combine.",
    "Pour in the coconut milk and bring the mixture to a simmer.",
    "Reduce the heat to low and let the stew cook for 20 minutes, or until the potatoes are tender.",
    "Stir in the grated tempering chocolate until melted and smooth.",
    "Season the stew with salt and pepper to taste.",
    "Garnish with chopped green onions and toasted sesame seeds.",
    "Serve the stew hot, over rice or noodles if desired."
  ],
