{
  "title": "Unctuous Creamy Korean Potato Stew",
  "description": "A comforting and creamy Korean stew featuring small potatoes and tempering chocolate, inspired by the cuisine of Busan, with ayurvedic tamasic friendly ingredients.",
  "cuisine": "Korean",
  "diet": [
    "vegetarian",
    "gluten-free"
  ],
