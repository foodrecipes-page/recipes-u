{
  "title": "Umami Crispy Argentinian Flour Empanadas",
  "description": "A savory and energizing empanada dish featuring dashi-extract and self-raising flour, perfect as a snack or light meal.",
  "cuisine": "argentinian",
  "diet": [
    "vegetarian",
    "gluten-free"
