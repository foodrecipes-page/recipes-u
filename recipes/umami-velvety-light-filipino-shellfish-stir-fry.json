      "amount": "1 tablespoon"
    },
    {
      "name": "Fish sauce",
      "amount": "2 tablespoons"
    },
    {
      "name": "Soy sauce, low sodium",
      "amount": "1 tablespoon"
    },
    {
      "name": "Olive oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "Red pepper flakes",
      "amount": "1/4 teaspoon"
    }
  ],
  "instructions": [
    "Heat olive oil in a large skillet over medium-high heat.",
    "Add onion and garlic, sauté until softened (about 3 minutes).",
    "Add shrimp and clams to the skillet; stir-fry for about 2-3 minutes or until the seafood is opaque.",
    "Stir in vegetable broth, fish sauce, soy sauce, and red pepper flakes. Bring to a simmer.",
    "Blend tahini with water to create a smooth paste (about 1 tablespoon of water per 1 tablespoon tahini), then stir into the dish.",
    "Reduce heat to low and let cook for another 2-3 minutes or until the broth thickens slightly.",
    "Garnish with green onions before serving."
  ],
