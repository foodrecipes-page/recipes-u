      "amount": "1 cup (shredded or in halves)"
    },
    {
      "name": "Onion, finely chopped",
      "amount": "1/4 cup"
    },
    {
      "name": "Garlic cloves, minced",
      "amount": "2-3 cloves"
    },
    {
      "name": "Green onions, sliced",
      "amount": "1/4 cup"
    },
    {
