  "instructions": [
    "Rinse the buckwheat and soak it in water for 30 minutes",
    "Drain and toast the buckwheat in a pan over medium heat for 5 minutes",
    "Add the chopped sage to the pan and stir for 1 minute",
    "Add the diced onion and grated carrot to the pan and stir for 3 minutes",
    "Add the sliced mushroom to the pan and stir for 4 minutes",
    "Add the diced candy to the pan and stir for 1 minute",
    "Add the olive oil, salt, and black pepper to the pan and stir for 1 minute",
    "Add the water to the pan and bring to a boil",
    "Reduce the heat to low and simmer for 15 minutes",
    "Serve the pilaf hot and enjoy"
