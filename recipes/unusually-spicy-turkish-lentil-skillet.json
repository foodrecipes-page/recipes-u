  "instructions": [
    "heat the olive oil in a large cast-iron skillet over medium-high heat.",
    "add the sliced onion and cook until translucent, about 5 minutes.",
    "add the minced garlic and cook for 1 minute, until fragrant.",
    "add the sliced carrot and red bell pepper and cook for 5 minutes, until the vegetables are slightly tender.",
    "add the red split lentils, salt, black pepper, and red pepper flakes. stir to combine.",
    "add 2 cups of water to the skillet and bring to a boil.",
    "transfer the skillet to a sous-vide water bath at 185f and cook for 30 minutes.",
    "remove the skillet from the water bath and stir in the lemon juice and chopped parsley.",
    "serve the skillet hot, garnished with additional parsley if desired."
