{
  "title": "Umami Flaky Russian Stir-fry",
  "description": "A kid-friendly and paleo-friendly umami-flavored dish featuring dried apricots that are slowly cooked for a delightful texture.",
  "cuisine": "Russian",
  "diet": [
    "paleo"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "chicken breast",
      "amount": "100g",
      "notes": "cut into small cubes"
    },
    {
      "name": "dried apricots",
      "amount": "3 tablespoons",
      "notes": "finely chopped"
    },
    {
      "name": "butter",
      "amount": "2 tbsp",
      "notes": "unsalted, softened"
    },
    {
      "name": "garlic cloves",
      "amount": "2",
      "notes": "minced"
    },
    {
      "name": "salt",
      "amount": "1/4 tsp",
      "notes": "to taste"
    },
    {
      "name": "black pepper",
      "amount": "1/4 tsp",
      "notes": "to taste"
    },
    {
      "name": "chicken broth",
      "amount": "150ml",
      "notes": "unsalted"
    },
    {
      "name": "zest of 1 lemon",
      "amount": "-",
      "notes": ""
    }
  ],
  "instructions": [
    "Preheat the oven to 375°F (190°C).",
    "Place chicken cubes on a baking sheet and roast for about 20 minutes, or until fully cooked.",
    "While chicken is roasting, soften butter in a pan over medium heat.",
    "Add minced garlic to the butter mixture and cook for another minute.",
    "Fold in finely chopped dried apricots and lemon zest. Stir well.",
    "Stir in roasted chicken cubes and season with salt and pepper. Cook until heated through and smooth.",
    "Serve hot as a side dish or main course."
  ],
