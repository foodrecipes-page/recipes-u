      "name": "cooked kidney beans",
      "amount": "1 cup",
      "notes": "rinsed and drained"
    },
    {
      "name": "agemono deep‑fry batter",
      "amount": "200g",
      "notes": "used for crisp coating"
    },
    {
      "name": "diced cucumber",
      "amount": "1 cup",
      "notes": "freshly chopped"
    },
    {
      "name": "diced tomato",
      "amount": "1 cup",
      "notes": "seeded and chopped"
    },
    {
      "name": "chopped fresh coriander",
      "amount": "1/4 cup",
      "notes": "finely chopped"
    },
    {
      "name": "chopped fresh mint",
      "amount": "1/4 cup",
      "notes": "finely chopped"
    },
    {
