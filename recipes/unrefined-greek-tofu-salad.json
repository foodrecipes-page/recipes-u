  "ingredients": [
    {
      "name": "extra-firm tofu",
      "amount": "400 g"
    },
    {
      "name": "olive oil",
      "amount": "2 tbsp"
    },
    {
      "name": "grapefruit juice",
      "amount": "2 tbsp"
    },
    {
      "name": "red onion",
      "amount": "1/4 medium, sliced"
    },
    {
      "name": "kalamata olives",
      "amount": "1/4 cup, pitted"
    },
    {
      "name": "cherry tomatoes",
      "amount": "1 cup, halved"
    },
    {
      "name": "cucumber",
      "amount": "1/2, diced"
    },
    {
      "name": "fresh dill",
      "amount": "2 tbsp, chopped"
    },
    {
      "name": "toasted pumpkin seeds",
      "amount": "1/4 cup"
    },
    {
      "name": "fresh lemon juice",
      "amount": "1 tbsp"
    },
    {
      "name": "salt",
      "amount": "1/2 tsp"
    },
    {
      "name": "black pepper",
      "amount": "1/4 tsp"
    }
  ],
  "instructions": [
    "Press tofu to remove excess moisture for 15 minutes.",
    "Cube tofu into bite-sized pieces.",
    "Heat 1 tbsp olive oil in a grill pan over medium heat and sear tofu until golden on all sides, about 6 minutes, turning occasionally.",
    "Whisk together grapefruit juice, remaining olive oil, lemon juice, salt, and pepper in a bowl.",
    "Toss the grilled tofu in the citrus vinaigrette until well coated.",
    "Transfer tofu to a large bowl and add sliced onion, olives, tomatoes, cucumber, dill, and pumpkin seeds, stirring gently.",
    "Chill the salad in the refrigerator for at least 30 minutes to meld flavors.",
    "Serve cold or at room temperature, optionally garnished with extra dill."
  ],
